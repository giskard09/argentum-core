{
  "description": "JCS (RFC 8785) profile for decision evidence (decision_id) preimage — execution-join-ref-v1",
  "encoding": "UTF-8",
  "field_set": ["action_ref", "canonicalization_profile_id", "outcome", "policy_id", "ts_ms", "version"],
  "key_order": "lexicographic",
  "name": "jcs-rfc8785-v1",
  "per_field_units": {
