    "outcome": {"type": "string", "enum": ["permit", "deny", "defer"]},
    "policy_id": {"type": "string"},
    "ts_ms": {
      "type": "integer",
      "unit": "milliseconds since Unix epoch",
      "note": "integer — NOT string. Decision timestamp."
    },
    "version": {"type": "string", "const": "execution-join-ref-v1"}
  },
  "serialization": "RFC8785-JCS",
  "spec_ref": "docs/spec/execution-join-ref-v1.md"
